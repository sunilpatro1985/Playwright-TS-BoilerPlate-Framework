# Copy this file to .env and fill in real values. .env is gitignored — never commit real credentials.
# In CI, set ENCRYPTION_KEY as a pipeline secret instead of using a file.

# Decrypts credentials.enc.json into the role/env/region credential store (see credentials.example.json).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Optional: which role's credentials getCredentials() resolves when a test doesn't pass one explicitly.
# Defaults to "default" when omitted.
ROLE=
